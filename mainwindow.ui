  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget {
    background-color: #F5F3EF;
    border: 2px solid #D8D5CC;
    border-radius: 18px;
}

/* ===== ОРНАМЕНТАЛНА РАМКА ===== */
QWidget#decoFrame {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FAFAF8, stop:1 #F0EEE8);
    border: 1px solid #D0CCC2;
    border-radius: 16px;
}

/* ===== ХЕДЪР ===== */
QWidget#headerContainer {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FFFFFF, stop:1 #FAF9F6);
    border: 1px solid #E0DDD5;
    border-radius: 14px;
}

/* ===== РАЗДЕЛИТЕЛНА ЛИНИЯ ===== */
QFrame#separator {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #FFFFFF, stop:0.3 #00966E, stop:0.7 #00966E, stop:1 #D62612);
    border: none;
    border-radius: 2px;
    min-height: 3px;
    max-height: 3px;
}

/* ===== ОРНАМЕНТ ===== */
QLabel#ornamentLeft, QLabel#ornamentRight {
    background: transparent;
    border: none;
    color: #00966E;
    font-size: 14px;
}

/* ===== ДИСПЛЕЙ ===== */
QLineEdit#display {
    background-color: #FFFFFF;
    border: 2px solid #D8D5CC;
    border-radius: 12px;
    padding: 8px 18px;
    color: #2C2C2C;
    font-size: 28px;
    font-weight: bold;
    selection-background-color: #00966E;
    selection-color: #FFFFFF;
}

/* ===== КНОПКИ ===== */
QPushButton {
    font-size: 16px;
    font-weight: 700;
    border: none;
    border-radius: 10px;
    padding: 5px;
    min-height: 48px;
}

QPushButton:pressed {
    padding-top: 8px;
    padding-left: 7px;
}

/* ---- Цифри (перленобял градиент) ---- */
QPushButton#btn0, QPushButton#btn1, QPushButton#btn2,
QPushButton#btn3, QPushButton#btn4, QPushButton#btn5,
QPushButton#btn6, QPushButton#btn7, QPushButton#btn8,
QPushButton#btn9 {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FEFEFE, stop:0.4 #FCFCFA, stop:1 #F0EFEA);
    color: #2C2C2C;
    border: 1px solid #D8D5CC;
    border-bottom: 5px solid #C4C0B6;
}
QPushButton#btn0:hover, QPushButton#btn1:hover, QPushButton#btn2:hover,
QPushButton#btn3:hover, QPushButton#btn4:hover, QPushButton#btn5:hover,
QPushButton#btn6:hover, QPushButton#btn7:hover, QPushButton#btn8:hover,
QPushButton#btn9:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #F8F8F6, stop:0.4 #F4F4F0, stop:1 #E8E7E0);
    border: 1px solid #00966E;
    border-bottom: 5px solid #007A59;
}
QPushButton#btn0:pressed, QPushButton#btn1:pressed, QPushButton#btn2:pressed,
QPushButton#btn3:pressed, QPushButton#btn4:pressed, QPushButton#btn5:pressed,
QPushButton#btn6:pressed, QPushButton#btn7:pressed, QPushButton#btn8:pressed,
QPushButton#btn9:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #E0DED6, stop:0.5 #E8E7E0, stop:1 #F0EFEA);
    border-bottom: 1px solid #C4C0B6;
}

/* ---- Точка ---- */
QPushButton#btnDot {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FEFEFE, stop:0.4 #FCFCFA, stop:1 #F0EFEA);
    color: #2C2C2C;
    border: 1px solid #D8D5CC;
    border-bottom: 5px solid #C4C0B6;
}
QPushButton#btnDot:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #F8F8F6, stop:0.4 #F4F4F0, stop:1 #E8E7E0);
    border: 1px solid #00966E;
    border-bottom: 5px solid #007A59;
}
QPushButton#btnDot:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #E0DED6, stop:0.5 #E8E7E0, stop:1 #F0EFEA);
    border-bottom: 1px solid #C4C0B6;
}

/* ---- Оператори (изумрудено зелено) ---- */
QPushButton#btnDivide, QPushButton#btnMultiply,
QPushButton#btnMinus, QPushButton#btnPlus {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #00B882, stop:0.4 #009E72, stop:1 #00805C);
    color: #FFFFFF;
    font-size: 22px;
    border-bottom: 5px solid #006347;
}
QPushButton#btnDivide:hover, QPushButton#btnMultiply:hover,
QPushButton#btnMinus:hover, QPushButton#btnPlus:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #00CC90, stop:0.4 #00B07A, stop:1 #009066);
    border-bottom: 5px solid #005A3E;
}
QPushButton#btnDivide:pressed, QPushButton#btnMultiply:pressed,
QPushButton#btnMinus:pressed, QPushButton#btnPlus:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #006347, stop:0.5 #00805C, stop:1 #009E72);
    border-bottom: 1px solid #006347;
}

/* ---- Функции (аквамарин) ---- */
QPushButton#btnSqrt, QPushButton#btnInv,
QPushButton#btnSin, QPushButton#btnCos,
QPushButton#btnTg, QPushButton#btnCtg {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #F2FCF8, stop:0.4 #EBF9F3, stop:1 #D8F2E6);
    color: #006347;
    border: 1px solid #C8E6D8;
    border-bottom: 5px solid #A8D0BA;
    font-size: 13px;
}
QPushButton#btnSqrt:hover, QPushButton#btnInv:hover,
QPushButton#btnSin:hover, QPushButton#btnCos:hover,
QPushButton#btnTg:hover, QPushButton#btnCtg:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #E8FAF0, stop:0.4 #DCF4E8, stop:1 #C8ECD8);
    border: 1px solid #00966E;
    border-bottom: 5px solid #00966E;
}
QPushButton#btnSqrt:pressed, QPushButton#btnInv:pressed,
QPushButton#btnSin:pressed, QPushButton#btnCos:pressed,
QPushButton#btnTg:pressed, QPushButton#btnCtg:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #B8DBC8, stop:0.5 #C8E6D8, stop:1 #D8F2E6);
    border-bottom: 1px solid #A8D0BA;
}

/* ---- Действия (рубиненочервени) ---- */
QPushButton#btnOpenParen, QPushButton#btnCloseParen,
QPushButton#btnClear, QPushButton#btnDelete {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #E6442E, stop:0.4 #D62E18, stop:1 #B82210);
    color: #FFFFFF;
    font-size: 15px;
    border-bottom: 5px solid #8E1A0C;
}
QPushButton#btnOpenParen:hover, QPushButton#btnCloseParen:hover,
QPushButton#btnClear:hover, QPushButton#btnDelete:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #F04C36, stop:0.4 #E0321C, stop:1 #CA2816);
    border-bottom: 5px solid #7E160A;
}
QPushButton#btnOpenParen:pressed, QPushButton#btnCloseParen:pressed,
QPushButton#btnClear:pressed, QPushButton#btnDelete:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #8E1A0C, stop:0.5 #B82210, stop:1 #D62E18);
    border-bottom: 1px solid #8E1A0C;
}

/* ---- Музика ---- */
QPushButton#btnMusic {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #FEFEFE, stop:0.4 #FCFCFA, stop:1 #F0EFEA);
    color: #2C2C2C;
    font-size: 20px;
    border: 1px solid #D8D5CC;
    border-bottom: 3px solid #C4C0B6;
    border-radius: 8px;
}
QPushButton#btnMusic:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #F8F8F6, stop:0.4 #F4F4F0, stop:1 #E8E7E0);
    border: 1px solid #D62612;
    border-bottom: 3px solid #B51E0E;
    color: #D62612;
}
QPushButton#btnMusic:pressed {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #E0DED6, stop:0.5 #E8E7E0, stop:1 #F0EFEA);
    border-bottom: 1px solid #C4C0B6;
}

/* ---- Равно (трикольор с дълбочина) ---- */
QPushButton#btnEquals {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #FEFEFE, stop:0.28 #FEFEFE,
        stop:0.28 #009E72, stop:0.66 #009E72,
        stop:0.66 #D62E18, stop:1 #D62E18);
    color: #FFFFFF;
    font-size: 26px;
    font-weight: 900;
    border: 1px solid #C8C4BA;
    border-bottom: 6px solid #9A968C;
}
QPushButton#btnEquals:hover {
    border: 1px solid #00966E;
    border-bottom: 6px solid #00966E;
}
QPushButton#btnEquals:pressed {
    border-bottom: 1px solid #9A968C;
    padding-top: 10px;
}
</string>
